# ─── Portfolio Configuration ─────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEXT_PUBLIC_* vars are exposed to the browser—don't put secrets here.
#
# On Vercel, add these as Environment Variables in your project dashboard:
#   https://vercel.com/[your-team]/[project]/settings/environment-variables

# Identity
NEXT_PUBLIC_SITE_NAME="Your Name"
NEXT_PUBLIC_SITE_NAME_SHORT="Your.Name"              # used in navbar logo (dot becomes blue)
NEXT_PUBLIC_TAGLINE="Web Developer"
NEXT_PUBLIC_SITE_TITLE="Your Name — Web Developer"
NEXT_PUBLIC_SITE_DESCRIPTION="Full-stack web developer building modern websites for small businesses."
NEXT_PUBLIC_COPYRIGHT="Your Name"

# URL — must match your Vercel domain or custom domain
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# Contact
NEXT_PUBLIC_EMAIL="your@email.com"
NEXT_PUBLIC_CALENDLY="your-calendly-username"         # e.g. "yourname" (no https://)
NEXT_PUBLIC_WEB3FORMS_KEY=""                          # get one free at https://web3forms.com

# Google Search Console (optional — leave blank to skip)
NEXT_PUBLIC_GOOGLE_VERIFICATION=""

# Discord Presence (via Lanyard) — optional, leave blank to hide
NEXT_PUBLIC_DISCORD_ID=""                             # your Discord user ID (numbers)
NEXT_PUBLIC_DISCORD_USERNAME="username"

# Socials
NEXT_PUBLIC_GITHUB_URL="https://github.com/yourname"
NEXT_PUBLIC_INSTAGRAM_URL="https://instagram.com/yourname"

# Share text — used when copying link or sharing to socials
NEXT_PUBLIC_SHARE_TEXT="Check out this developer 👋"

# Location / Pricing — used in SEO meta and TrustBar
NEXT_PUBLIC_LOCATION="Your City, State"
NEXT_PUBLIC_PRICE_RANGE="$500 - $5,000"

# OG Image — replace /public/og-image.png with your own 1200x630 preview
# (the existing one has the original author's name on it)
