# ─── Portfolio Configuration ─────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEXT_PUBLIC_* vars are exposed to the browser—don't put secrets here.

# Identity
NEXT_PUBLIC_SITE_NAME="Your Name"
NEXT_PUBLIC_SITE_NAME_SHORT="Your.Name"
NEXT_PUBLIC_TAGLINE="Web Developer"
NEXT_PUBLIC_SITE_TITLE="Your Name — Web Developer"
NEXT_PUBLIC_SITE_DESCRIPTION="Full-stack web developer building modern websites for small businesses."
NEXT_PUBLIC_COPYRIGHT="Your Name"

# URL
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# Contact
NEXT_PUBLIC_EMAIL="your@email.com"
NEXT_PUBLIC_CALENDLY="your-calendly-username"
NEXT_PUBLIC_WEB3FORMS_KEY=""

# Google Search Console (optional)
NEXT_PUBLIC_GOOGLE_VERIFICATION=""

# Discord Presence (optional)
NEXT_PUBLIC_DISCORD_ID=""
NEXT_PUBLIC_DISCORD_USERNAME=""

# Socials
NEXT_PUBLIC_GITHUB_URL=""
NEXT_PUBLIC_INSTAGRAM_URL=""

# Location / Pricing
NEXT_PUBLIC_LOCATION="Your City, State"
NEXT_PUBLIC_PRICE_RANGE="$500 - $5,000"

# Share
NEXT_PUBLIC_SHARE_TEXT="Check out this developer 👋"

# ─── Secrets (NOT prefixed with NEXT_PUBLIC_) ────────────────
# On Vercel, add these in your project dashboard under Settings → Environment Variables.
# They are never exposed to the browser.

# Database (Neon Postgres)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Auth
AUTH_SECRET="generate with: openssl rand -base64 32"
AUTH_ADMIN_EMAIL="admin@yourdomain.com"
AUTH_ADMIN_PASSWORD="your-admin-password"

# Stripe (get test keys at https://dashboard.stripe.com/test/apikeys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."                     # from Stripe Dashboard → Webhooks
# Create products & prices in Stripe Dashboard, then paste IDs here:
STRIPE_ESSENTIAL_PRICE_ID="price_..."
STRIPE_GROWTH_PRICE_ID="price_..."
STRIPE_PREMIUM_PRICE_ID="price_..."
STRIPE_MAINTENANCE_PRICE_ID="price_..."               # monthly subscription addon
